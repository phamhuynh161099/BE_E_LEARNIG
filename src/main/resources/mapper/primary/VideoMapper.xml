<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.sakata.boilerplate.mapper.primary.VideoMapper">

    <resultMap id="VideoRM" type="com.sakata.boilerplate.models.Video">
        <id property="id" column="id" />
        <result property="originalFileName" column="original_file_name" />
        <result property="originalPath" column="original_path" />
        <result property="encoded720Path" column="encoded_720p_path" />
        <result property="encoded1080Path" column="encoded_1080p_path" />
        <result property="status" column="status" />
        <result property="fileSize" column="file_size" />
        <result property="duration" column="duration" />
        <result property="createdAt" column="created_at" />
    </resultMap>



    <resultMap id="TrackingVideoVO" type="com.sakata.boilerplate.models.vo.TrackingVideoVO">
        <id property="id" column="id" />
        <result property="originalFileName" column="original_file_name" />
        <result property="originalPath" column="original_path" />
        <result property="encoded720Path" column="encoded_720p_path" />
        <result property="encoded1080Path" column="encoded_1080p_path" />
        <result property="status" column="tv_status" />
        <result property="fileSize" column="file_size" />
        <result property="duration" column="duration" />
        <result property="createdAt" column="created_at" />
        <result property="jobId" column="job_id" />
        <result property="resolution" column="tv_resolution" />
    </resultMap>


    <select id="findById" resultMap="VideoRM">
        SELECT 
            id,
            original_file_name,
            original_path,
            encoded_720p_path, 
            encoded_1080p_path, 
            status, file_size,
            duration, 
            created_at 
        FROM videos
        WHERE id = #{id}
    </select>


     <!-- <select id="findAll" resultMap="VideoRM">
