            original_path,
            encoded_720p_path, 
            encoded_1080p_path, 
            status, file_size,
            duration, 
            created_at 
        FROM videos
    </select> -->


    <select id="findAll" resultMap="TrackingVideoVO">
        SELECT
            t1.id as id,
            t1.original_file_name,
            t1.original_path,
            t1.encoded_720p_path,
            t1.encoded_1080p_path,
            t1.file_size,
            t1.created_at,
            t2.job_id,
            t2.status as tv_status,
            t2.total_duration as tv_duration,
            t2.resolution as tv_resolution
        FROM
            videos t1
        LEFT JOIN tracking_video t2 
        ON t1.id = t2.video_id 
        ORDER BY t1.created_at desc
    </select>
</mapper>